ENVIRONMENT=DEV
DB_SOURCE=postgresql://root:secret@localhost:5432/phox-customer?sslmode=disable
CONNECT_SERVER_ADDRESS=localhost:8082

# JWT Configuration (Keycloak OIDC)
# NOTE: JWT_ISSUER_URL must exactly match the `iss` claim that browsers see in
# their tokens (so use the host name the browser uses). JWT_JWKS_URL is what
# this backend actually fetches to verify signatures, so use whatever hostname
# is reachable from *this* process. In docker-compose these hostnames differ.
JWT_ENABLED=true
JWT_PROJECT_ID=phox-customer
JWT_ISSUER_URL=http://localhost:8080/realms/phox
JWT_JWKS_URL=http://localhost:8080/realms/phox/protocol/openid-connect/certs

# Keycloak Admin API — used by CreateCompanyUser
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=phox
KEYCLOAK_ADMIN_CLIENT_ID=phox-admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=admin-cli-secret-local-only

# Elasticsearch — full-text customer search. If empty, search is disabled (degraded).
ELASTICSEARCH_URL=http://localhost:9200

# SMTP outbound mail. MailHog default (no TLS, port 1025).
# 本番 mailu に接続する場合: SMTP_PORT=465, SMTP_TLS_MODE=implicit,
# SMTP_USERNAME=<service account>, SMTP_PASSWORD=<secret>.
# mailu は STARTTLS 非推奨のため 587 は使わない。
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_DEFAULT_FROM=noreply@phox.local
SMTP_TLS_MODE=none

# Phase 20: Google Calendar 連携 (Redial)。
# dev/E2E は GCAL_MODE=mock でフェイククライアント化。本番は real に戻す。
# GCAL_TOKEN_KEY は base64 32 byte (AES-256 key)。下記は dev 専用の固定値。
GCAL_MODE=mock
GCAL_TOKEN_KEY=ZGV2LW9ubHktMzJieXRlLWtleS1mb3ItZGV2LWdjYWw=
GOOGLE_OAUTH_CLIENT_ID=dummy-for-dev
GOOGLE_OAUTH_CLIENT_SECRET=dummy-for-dev
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8082/oauth/google/callback
PHOX_BASE_URL=http://localhost:3000

# Phase 20e: iCalendar 購読 URL のベース。dev 既定は backend のローカル URL。
ICAL_FEED_BASE_URL=http://localhost:8082
