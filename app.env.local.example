# app.env.local.example — Phase 20 Google Calendar real mode の開発環境用テンプレート。
#
# 使い方:
#   cp app.env.local.example app.env.local
#   # app.env.local を編集して、下記プレースホルダを自分の値に置き換える
#
# このファイルは .gitignore されているので commit されない。
# 実際の OAuth Client ID/Secret は GCP Console で取得:
#   https://console.cloud.google.com/apis/credentials
#
# 詳細は docs/GOOGLE_OAUTH_SETUP.md を参照。

# Google Calendar real モードに切り替える
GCAL_MODE=real

# GCP Console で作成した OAuth 2.0 Client ID
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME

# OAuth client の承認済みリダイレクト URI とまったく同じにすること
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8082/oauth/google/callback

# GCAL_TOKEN_KEY は app.env の dev 用デフォルトでも OK だが、
# 本番では必ず 32 byte の秘密鍵を base64 で指定する
# GCAL_TOKEN_KEY=ZGV2LW9ubHktMzJieXRlLWtleS1mb3ItZGV2LWdjYWw=

# --- Phase 14b: mailu 接続 (実 SMTP/IMAP で送受信テストしたい時) ---
# 詳細は docs/MAILU_SETUP.md を参照。
#
# コメントを外せば MailHog ではなく実 mailu に向かう。
# E2E を回す時は必ずこの節をコメントアウトして MailHog に戻すこと。
#
# SMTP_HOST=mail.example.com
# SMTP_PORT=465
# SMTP_TLS_MODE=implicit
# SMTP_USERNAME=phox@example.com
# SMTP_PASSWORD=REPLACE_ME
# SMTP_DEFAULT_FROM=phox@example.com
#
# IMAP_HOST=mail.example.com
# IMAP_PORT=993
# IMAP_TLS_MODE=implicit
# IMAP_USERNAME=phox@example.com
# IMAP_PASSWORD=REPLACE_ME
# IMAP_SENT_MAILBOX=Sent
# IMAP_INBOX_MAILBOX=INBOX
# IMAP_POLL_INTERVAL=30s
# IMAP_TLS_INSECURE_SKIP_VERIFY=false
